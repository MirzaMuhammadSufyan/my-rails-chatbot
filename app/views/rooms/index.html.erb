<main class="rooms-app">
  <header class="rooms-topbar">
    <div class="rooms-topbar-text">
      <p class="rooms-eyebrow">Chatbot</p>
      <h1>Your rooms</h1>
    </div>
    <%= link_to root_path, class: "pill-link pill-link--accent" do %>
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
      General
    <% end %>
  </header>

  <div class="rooms-body">
    <% if flash[:notice] %>
      <p class="flash flash--notice" role="status"><%= flash[:notice] %></p>
    <% end %>
    <% if flash[:alert] %>
      <p class="flash flash--alert" role="alert"><%= flash[:alert] %></p>
    <% end %>

    <%= form_with url: session_path, method: :patch, local: true, class: "rooms-profile" do %>
      <span class="rooms-profile-avatar" aria-hidden="true"><%= current_user_name.to_s.first.upcase %></span>
      <div class="rooms-profile-fields">
        <label class="rooms-profile-label" for="user_name">Signed in as</label>
        <div class="rooms-profile-edit">
          <%= text_field_tag :user_name, current_user_name, id: "user_name", maxlength: 50, required: true, class: "rooms-profile-input", autocomplete: "nickname", aria: { label: "Display name" } %>
          <%= submit_tag "Save", class: "btn rooms-profile-save" %>
        </div>
      </div>
    <% end %>

    <section class="panel">
      <div class="panel-head">
        <h2 class="panel-title">Rooms</h2>
        <span class="panel-badge"><%= @rooms.size %></span>
      </div>
      <% if @rooms.any? %>
        <ul class="room-list">
          <% @rooms.each do |room| %>
            <li class="room-list-item">
              <%= link_to room, class: "room-item" do %>
                <span class="room-avatar" aria-hidden="true"><%= room.name.first.upcase %></span>
                <span class="room-info">
                  <span class="room-name">
                    <%= room.name %>
                    <% if room.password_protected? %>
                      <span class="room-lock" title="Password protected" aria-label="Password protected">🔒</span>
                    <% end %>
                  </span>
                  <span class="room-hint"><%= room.general? ? "Default room" : (room.password_protected? ? "Password protected" : "Tap to open") %></span>
                </span>
                <span class="room-chevron" aria-hidden="true">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
                </span>
              <% end %>
              <% unless room.general? %>
                <%= button_to room_path(room),
                      method: :delete,
                      class: "room-delete-btn",
                      title: "Delete room",
                      aria: { label: "Delete #{room.name}" },
                      form: {
                        class: "room-delete-form",
                        onsubmit: "return confirm('Delete “#{room.name}” and all its messages?')"
                      } do %>
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M3 6h18M8 6V4h8v2M19 6l-1 14H6L5 6"/></svg>
                <% end %>
              <% end %>
            </li>
          <% end %>
        </ul>
      <% else %>
        <p class="panel-empty">No rooms yet — create one below.</p>
      <% end %>
    </section>

    <section class="panel panel--create">
      <h2 class="panel-title">New room</h2>
      <%= form_with model: Room.new, url: rooms_path, local: true do |f| %>
        <div class="field">
          <%= f.label :name, "Room name" %>
          <%= f.text_field :name, required: true, placeholder: "Design, Dev, Random…" %>
        </div>
        <div class="field">
          <%= f.label :password, "Room password" %>
          <%= f.password_field :password, required: true, placeholder: "Set a password for this room…", autocomplete: "new-password" %>
          <p style="margin:0.35rem 0 0;font-size:0.75rem;color:var(--muted)">Anyone who wants to join will need this password.</p>
        </div>
        <%= f.submit "Create room", class: "btn btn-primary btn-block" %>
      <% end %>
    </section>
  </div>
</main>
