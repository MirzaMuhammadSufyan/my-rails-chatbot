<main class="app--auth">
  <div class="auth">
    <div class="auth-logo" aria-hidden="true">🔒</div>
    <h1 class="auth-title">Password Required</h1>
    <p class="auth-sub">Enter the password to access <strong><%= @room.name %></strong></p>

    <% if flash[:alert] %>
      <p class="alert" role="alert"><%= flash[:alert] %></p>
    <% end %>

    <%= form_with url: verify_password_room_path(@room), method: :post, local: true do %>
      <div class="field">
        <label for="room_password">Room password</label>
        <%= password_field_tag :room_password, nil, id: "room_password", required: true, autofocus: true, placeholder: "Enter password…", autocomplete: "current-password" %>
      </div>
      <%= submit_tag "Enter Room", class: "btn btn-primary btn-block" %>
    <% end %>

    <div style="margin-top:1.25rem;text-align:center">
      <%= link_to "← Back to rooms", rooms_path, style: "font-size:0.875rem;color:var(--text-2)" %>
    </div>
  </div>
</main>
