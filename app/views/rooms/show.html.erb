<div class="chat-shell">
  <main class="chat-app">
    <header class="chat-topbar">
      <%= link_to rooms_path, class: "chat-topbar-back", aria: { label: "Back to rooms" } do %>
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M15 18l-6-6 6-6"/></svg>
      <% end %>
      <div class="chat-topbar-avatar" aria-hidden="true"><%= @room.name.first.upcase %></div>
      <div class="chat-topbar-info">
        <h1><%= @room.name %></h1>
        <p><span class="status-dot" aria-hidden="true"></span> Live · <%= current_user_name %></p>
      </div>
      <div class="chat-topbar-actions">
        <% if current_user_name.to_s.strip.downcase == "admin" %>
          <%= button_to clear_messages_room_path(@room),
                method: :post,
                class: "icon-btn chat-topbar-clear",
                title: "Clear chat history",
                aria: { label: "Clear chat" },
                form: { onsubmit: "return confirm('Clear all messages in this room?')", style: "display:inline" } do %>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M3 6h18M8 6V4h8v2M19 6l-1 14H6L5 6"/></svg>
          <% end %>
        <% end %>

        <%# Call buttons — audio & video %>
        <button type="button" class="icon-btn call-start-btn" data-call-action="start-audio" title="Audio call" aria-label="Start audio call">
          <svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.38 2 2 0 0 1 3.6 1.18h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.77a16 16 0 0 0 6 6l.95-.95a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        </button>
        <button type="button" class="icon-btn call-start-btn" data-call-action="start-video" title="Video call" aria-label="Start video call">
          <svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2"/></svg>
        </button>

        <span class="chat-topbar-live" aria-label="Connected">Online</span>
      </div>
    </header>

    <%# Bulk select action bar — shown when messages are selected %>
    <div id="bulk-action-bar" class="bulk-action-bar" hidden>
      <span id="bulk-count" class="bulk-count">0 selected</span>
      <div class="bulk-actions">
        <button type="button" id="bulk-cancel" class="btn bulk-btn bulk-btn--cancel">Cancel</button>
        <button type="button" id="bulk-delete" class="btn bulk-btn bulk-btn--delete"
          data-bulk-url="<%= bulk_destroy_room_messages_path(@room) %>">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M3 6h18M8 6V4h8v2M19 6l-1 14H6L5 6"/></svg>
          Delete Selected
        </button>
      </div>
    </div>

    <div class="chat-feed-wrap">
      <div id="messages" class="chat-feed" data-chat-room data-room-id="<%= @room.id %>" data-current-user="<%= current_user_name %>" data-is-admin="<%= current_user_name.to_s.strip.downcase == "admin" %>">
        <% if @messages.empty? %>
          <div class="chat-empty" aria-hidden="false">
            <div class="chat-empty-icon" aria-hidden="true">💬</div>
            <p class="chat-empty-title">No messages yet</p>
            <p class="chat-empty-text">Say hello — everyone in this room will see it instantly.</p>
          </div>
        <% else %>
          <%= render @messages %>
        <% end %>
      </div>
    </div>

    <footer class="chat-dock">
      <%= form_with url: room_messages_path(@room), method: :post, local: true, html: { id: "chat-form", class: "chat-form", enctype: "multipart/form-data" } do %>
        <div id="reply-bar" class="reply-bar" hidden>
          <div class="reply-bar-content">
            <span class="reply-bar-label">Replying to <strong id="reply-bar-author"></strong></span>
            <span id="reply-bar-preview" class="reply-bar-preview"></span>
          </div>
          <button type="button" id="reply-bar-cancel" class="reply-bar-cancel" aria-label="Cancel reply">&times;</button>
          <input type="hidden" name="message[reply_to_id]" id="message_reply_to_id" value="">
        </div>

        <div id="emoji-picker" class="emoji-panel" role="listbox" aria-label="Emoji picker" hidden></div>

        <div id="voice-recording-ui" class="voice-recording-ui" hidden>
          <button type="button" id="voice-cancel" class="voice-action-btn" aria-label="Cancel recording">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6L6 18M6 6l12 12"/></svg>
          </button>
          <div class="voice-recording-main">
            <span class="voice-rec-dot" aria-hidden="true"></span>
            <span id="voice-timer" class="voice-timer">0:00</span>
            <div id="voice-waveform" class="voice-waveform" aria-hidden="true"></div>
          </div>
          <button type="button" id="stop-voice" class="voice-action-btn voice-action-btn--send" aria-label="Stop recording">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><rect x="6" y="6" width="12" height="12" rx="2"/></svg>
          </button>
        </div>

        <div id="voice-draft-ui" class="voice-draft-ui" hidden>
          <button type="button" id="voice-discard" class="voice-action-btn" aria-label="Delete voice message">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18M8 6V4h8v2M19 6l-1 14H6L5 6"/></svg>
          </button>
          <div class="voice-draft-main">
            <button type="button" id="voice-play-preview" class="voice-play-btn" aria-label="Play preview">
              <span class="voice-play-icon" aria-hidden="true"></span>
            </button>
            <div id="voice-draft-wave" class="voice-draft-wave" aria-hidden="true"></div>
            <span id="voice-draft-duration" class="voice-draft-duration">0:00</span>
          </div>
          <p class="voice-draft-hint">Enter to send</p>
          <button type="submit" class="send-btn voice-draft-send" aria-label="Send voice message">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><path d="M22 2L11 13"/><path d="M22 2l-7 20-4-9-9-4 20-7z"/></svg>
          </button>
        </div>

        <%# Video recording UI %>
        <div id="video-recording-ui" class="video-recording-ui" hidden>
          <button type="button" id="video-cancel" class="voice-action-btn" aria-label="Cancel video">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6L6 18M6 6l12 12"/></svg>
          </button>
          <div class="video-recording-main">
            <video id="video-preview-live" class="video-preview-live" muted autoplay playsinline aria-hidden="true"></video>
            <span class="voice-rec-dot" aria-hidden="true"></span>
            <span id="video-timer" class="voice-timer">0:00</span>
          </div>
          <button type="button" id="stop-video" class="voice-action-btn voice-action-btn--send" aria-label="Stop video">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><rect x="6" y="6" width="12" height="12" rx="2"/></svg>
          </button>
        </div>

        <div class="chat-composer" id="chat-composer">
          <details class="attach-dropdown">
            <summary class="icon-btn icon-btn--attach-toggle" aria-label="Attach file">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14M5 12h14"/></svg>
            </summary>
            <div class="attach-menu" role="menu">
              <label class="attach-menu-item" role="menuitem">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
                Photo
                <input type="file" id="message_media_image" accept="image/*" data-media-input data-kind="image">
              </label>
              <label class="attach-menu-item" role="menuitem">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2"/></svg>
                Video
                <input type="file" id="message_media_video" accept="video/*" data-media-input data-kind="video">
              </label>
              <label class="attach-menu-item" role="menuitem">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>
                Audio
                <input type="file" id="message_media_audio" accept="audio/*" data-media-input data-kind="audio">
              </label>
              <label class="attach-menu-item" role="menuitem">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/></svg>
                File
                <input type="file" id="message_media_file" accept="*/*" data-media-input data-kind="file">
              </label>
            </div>
          </details>

          <button type="button" id="emoji-toggle" class="icon-btn" aria-label="Emoji" aria-expanded="false" aria-controls="emoji-picker">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/></svg>
          </button>

          <label class="sr-only" for="message_body">Message</label>
          <textarea name="message[body]" id="message_body" rows="1" placeholder="Message..."></textarea>

          <button type="button" id="record-video" class="icon-btn" aria-label="Record video" title="Record video">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2"/></svg>
          </button>

          <button type="button" id="record-voice" class="icon-btn" aria-label="Record voice">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/></svg>
          </button>

          <button type="submit" id="send-message" class="send-btn" aria-label="Send message">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><path d="M22 2L11 13"/><path d="M22 2l-7 20-4-9-9-4 20-7z"/></svg>
          </button>
        </div>
      <% end %>
    </footer>

    <div id="pending-media-overlay" class="pending-media-overlay" hidden aria-modal="true" role="dialog" aria-label="Attachment preview">
      <button type="button" id="pending-media-cancel" class="pending-media-close" aria-label="Cancel attachment">&times;</button>
      <div id="pending-media-visual" class="pending-media-visual-full"></div>
      <div class="pending-media-bar">
        <p id="pending-media-name" class="pending-media-name"></p>
        <div class="pending-media-actions">
          <p class="pending-media-hint">Esc to cancel</p>
          <button type="button" id="pending-media-send" class="pending-media-send" aria-label="Send attachment">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" aria-hidden="true"><path d="M22 2L11 13"/><path d="M22 2l-7 20-4-9-9-4 20-7z"/></svg>
            Send
          </button>
        </div>
      </div>
    </div>

    <div id="media-lightbox" class="media-lightbox" hidden aria-hidden="true" role="dialog" aria-modal="true" aria-label="Media viewer">
      <button type="button" class="media-lightbox-backdrop" aria-label="Close"></button>
      <button type="button" class="media-lightbox-close" aria-label="Close">&times;</button>
      <div class="media-lightbox-body">
        <p class="media-lightbox-zoom-hint" id="media-lightbox-hint" hidden>Ctrl + scroll to zoom (up to 300%)</p>
      </div>
    </div>

    <%# ── Incoming ring overlay ─────────────────────────────────────────────── %>
    <div id="call-incoming-ring" class="call-ring" hidden role="dialog" aria-modal="true" aria-label="Incoming call">
      <div class="call-ring-inner">
        <div class="call-ring-avatar" aria-hidden="true">
          <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
        </div>
        <p class="call-ring-caller">Someone</p>
        <p class="call-ring-type">Video call</p>
        <div class="call-ring-pulse" aria-hidden="true"></div>
        <div class="call-ring-btns">
          <button type="button" class="call-ring-btn call-ring-btn--reject" data-call-action="reject" aria-label="Decline call">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true"><path d="M1 1l22 22"/><path d="M16.72 11.06A10.94 10.94 0 0 1 19 12.55"/><path d="M5 12.55a10.94 10.94 0 0 1 5.17-2.39"/><path d="M10.71 5.05A16 16 0 0 1 22.56 9"/><path d="M1.42 9a15.91 15.91 0 0 1 4.7-2.88"/><path d="M8.51 16.48a16 16 0 0 0 5.49 1.49"/><path d="M15.5 16.48c1.86-.48 3.68-1.5 5.5-1.49"/></svg>
          </button>
          <button type="button" class="call-ring-btn call-ring-btn--answer call-ring-btn--audio" data-call-action="answer-audio" aria-label="Answer audio only">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.38 2 2 0 0 1 3.6 1.18h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.77a16 16 0 0 0 6 6l.95-.95a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          </button>
          <button type="button" class="call-ring-btn call-ring-btn--answer" data-call-action="answer-video" aria-label="Answer with video">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true"><polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2"/></svg>
          </button>
        </div>
      </div>
    </div>

    <%# ── Active call overlay ─────────────────────────────────────────────── %>
    <div id="call-overlay" class="call-overlay" hidden data-call-state="idle" role="dialog" aria-modal="true" aria-label="Active call">
      <%# Remote full-screen feed %>
      <div class="call-remote-wrap">
        <video id="call-remote-video" class="call-remote-video" autoplay playsinline></video>
        <div class="call-remote-placeholder" aria-hidden="true">
          <svg width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
        </div>
        <div class="call-remote-meta">
          <span id="call-remote-name" class="call-remote-name">…</span>
          <span id="call-timer" class="call-timer"></span>
          <span class="call-state-label" data-show-on="calling">Calling…</span>
          <span class="call-state-label" data-show-on="connected">Connected</span>
        </div>
        <%# Fullscreen toggle — bottom-right of video frame %>
        <button id="call-fullscreen-btn" type="button" class="call-fullscreen-btn" data-call-action="fullscreen" aria-label="Full screen" touch-action="manipulation">
          <svg class="icon-expand" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M8 3H5a2 2 0 0 0-2 2v3m18 0V5a2 2 0 0 0-2-2h-3m0 18h3a2 2 0 0 0 2-2v-3M3 16v3a2 2 0 0 0 2 2h3"/></svg>
          <svg class="icon-compress" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" hidden><path d="M8 3v3a2 2 0 0 1-2 2H3m18 0h-3a2 2 0 0 1-2-2V3m0 18v-3a2 2 0 0 1 2-2h3M3 16h3a2 2 0 0 1 2 2v3"/></svg>
        </button>
      </div>

      <%# In-call chat panel %>
      <div id="call-chat-panel" class="call-chat-panel" hidden>
        <div class="call-chat-header">
          <span>Messages</span>
          <button type="button" class="call-chat-close" data-call-action="close-chat" aria-label="Close chat">&times;</button>
        </div>
        <div id="call-chat-messages" class="call-chat-messages"></div>
        <form id="call-chat-form" class="call-chat-form" autocomplete="off">
          <input id="call-chat-input" type="text" class="call-chat-input" placeholder="Type a message…" maxlength="1000">
          <button type="submit" class="call-chat-send" aria-label="Send">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
          </button>
        </form>
      </div>

      <%# Local PiP — draggable %>
      <div id="call-local-pip" class="call-local-pip">
        <video id="call-local-video" class="call-local-video" autoplay muted playsinline></video>
        <div class="call-local-avatar" aria-hidden="true">
          <span id="call-local-name" class="call-local-initial"><%= current_user_name.to_s.first.upcase %></span>
        </div>
      </div>

      <%# Controls bar %>
      <div class="call-controls">
        <button id="call-mute-btn" type="button" class="call-ctrl-btn" data-call-action="mute" aria-label="Mute">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/></svg>
          <span class="call-ctrl-label">Mute</span>
        </button>
        <button id="call-cam-btn" type="button" class="call-ctrl-btn" data-call-action="camera" aria-label="Turn off camera">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2"/></svg>
          <span class="call-ctrl-label">Camera</span>
        </button>
        <button id="call-switch-camera-btn" type="button" class="call-ctrl-btn" data-call-action="switch-camera" aria-label="Switch camera">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M4 7v6h6"/><path d="M20 17v-6h-6"/><path d="M9 7L4 2"/><path d="M15 17l5 5"/></svg>
          <span class="call-ctrl-label">Switch</span>
        </button>
        <button id="call-chat-btn" type="button" class="call-ctrl-btn" data-call-action="chat" aria-label="Messages" style="position:relative">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
          <span class="call-ctrl-label">Chat</span>
          <span class="call-chat-btn-badge"></span>
        </button>
        <button type="button" class="call-ctrl-btn call-ctrl-btn--hangup" data-call-action="hangup" aria-label="End call">
          <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true"><path d="M1 1l22 22M16.72 11.06A10.94 10.94 0 0 1 19 12.55M5 12.55a10.94 10.94 0 0 1 5.17-2.39M10.71 5.05A16 16 0 0 1 22.56 9M1.42 9a15.91 15.91 0 0 1 4.7-2.88M8.51 16.48a16 16 0 0 0 5.49 1.49M15.5 16.48c1.86-.48 3.68-1.5 5.5-1.49"/></svg>
          <span class="call-ctrl-label">End</span>
        </button>
        <button id="call-speaker-btn" type="button" class="call-ctrl-btn" data-call-action="speaker" aria-label="Speaker">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14"/><path d="M15.54 8.46a5 5 0 0 1 0 7.07"/></svg>
          <span class="call-ctrl-label">Speaker</span>
        </button>
      </div>
    </div>
  </main>
</div>
