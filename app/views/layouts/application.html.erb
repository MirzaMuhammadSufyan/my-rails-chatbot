<!DOCTYPE html>
<html lang="en">
  <head>
    <title><%= content_for(:title) || "Chatbot" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover">
    <meta name="theme-color" content="#0f1419">
    <meta name="color-scheme" content="dark">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= action_cable_meta_tag %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="app<%= " app--auth" if controller_name == "sessions" || (controller_name == "rooms" && action_name == "password") %><%= " app--chat" if controller_name == "rooms" && action_name == "show" %><%= " app--rooms" if controller_name == "rooms" && action_name == "index" %>">
    <div class="app-glow" aria-hidden="true"></div>
    <%= yield %>
  </body>
</html>
