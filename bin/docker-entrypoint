#!/bin/bash -e

# Enable jemalloc for reduced memory usage and latency.
if [ -z "${LD_PRELOAD+x}" ]; then
    LD_PRELOAD=$(find /usr/lib -name libjemalloc.so.2 -print -quit)
    export LD_PRELOAD
fi

if [ -z "${RAILS_MASTER_KEY:-}" ] && [ -z "${SECRET_KEY_BASE:-}" ]; then
  echo "ERROR: Set RAILS_MASTER_KEY or SECRET_KEY_BASE in Render environment variables." >&2
  exit 1
fi

# Migrate when starting the web server (Docker / Render).
if [[ "$*" == *"puma"* ]] || [[ "${@: -1:1}" == "server" ]]; then
  ./bin/rails db:prepare
fi

exec "${@}"
